# ForgeCRM — environment template. Copy to `.env.local` and fill in.
#   cp .env.local.example .env.local
#
# The app runs FULLY without this key — the two AI calls (rule compiler, quote
# builder) fall back to deterministic canned objects keyed to the demo prompts, so
# the entire demo works offline. Set the key only to use real Claude.
#
# In Vercel: add ANTHROPIC_API_KEY under Project → Settings → Environment Variables
# (Production + Preview). Never commit the real key — .env.local is gitignored.

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
